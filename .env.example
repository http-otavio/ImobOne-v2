# .env.example — ImobOne-v2
#
# Copie para .env e preencha os valores antes do deploy:
#   cp .env.example .env
#
# NUNCA commitar o .env com valores reais.
# O .env é carregado pelo docker-compose.yml via env_file.

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── OpenAI (embeddings — text-embedding-3-small) ─────────────────────────────
OPENAI_API_KEY=

# ── Google APIs ──────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
GOOGLE_DISTANCE_MATRIX_API_KEY=

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://gzhgjjwnmwvjqitkvrhm.supabase.co
SUPABASE_KEY=
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.gzhgjjwnmwvjqitkvrhm.supabase.co:5432/postgres

# ── Redis (serviço na rede OtavioNet do Swarm) ────────────────────────────────
# No VPS com Docker Swarm, o Redis já roda como serviço n8n_n8n_redis na OtavioNet.
# Para desenvolvimento local com Redis instalado: redis://localhost:6379
REDIS_URL=redis://n8n_n8n_redis:6379

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=

# ── WhatsApp Business API (BSP — 360dialog ou Gupshup) ───────────────────────
# Canal único. Evolution API descartada — risco de ban inaceitável.
WHATSAPP_BSP_API_KEY=
WHATSAPP_BSP_URL=
# Número do operador para alertas do monitor (formato E.164: +5511999990000)
WHATSAPP_OPERATOR_NUMBER=

# ── Alertas internos ─────────────────────────────────────────────────────────
# Pelo menos um dos dois deve estar configurado para o monitor emitir alertas.
ALERT_SLACK_WEBHOOK=

# ── Dashboard ────────────────────────────────────────────────────────────────
# Segredo para assinar tokens JWT do dashboard do gestor.
DASHBOARD_SECRET_KEY=
